{$PLA_SITE_ADDRESS} {
  encode zstd gzip

  basic_auth {
    {$PLA_PILOT_USERNAME} {$PLA_PILOT_PASSWORD_HASH}
  }

  request_body {
    max_size 14MB
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  reverse_proxy app:3000 {
    flush_interval -1
    health_uri /api/health
    health_interval 30s
    health_timeout 5s
  }
}
