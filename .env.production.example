# Public hostname. Use a real domain so Caddy can issue an HTTPS certificate.
PLA_SITE_ADDRESS=physics.example.com

# Shared outer gate for a controlled pilot. Generate the hash with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext "your-password"
PLA_PILOT_USERNAME=tester
PLA_PILOT_PASSWORD_HASH='$2a$14$replace_with_a_caddy_password_hash'

# Server-side default model. Testers can alternatively use BYOK in API Settings.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_THINKING=disabled
DEEPSEEK_TIMEOUT_MS=120000

# The Compose stack mounts a persistent Docker volume at this path.
PLA_DATA_DIR=/data
PLA_ALLOW_PRIVATE_MODEL_ENDPOINTS=false
